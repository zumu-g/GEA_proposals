# Required
NEXT_PUBLIC_BASE_URL=https://proposals.grantsea.com.au
AGENTMAIL_API_KEY=your_agentmail_key
AGENTMAIL_INBOX=newproposal@agentmail.to

# Optional
AGENCY_EMAIL=info@grantsea.com.au
APIFY_API_TOKEN=your_apify_token

# Railway volume (set automatically if using volume mount)
# DATABASE_PATH=/data/gea.db
# DATA_DIR=/data

# everypropertyAI (PropertyIQ data via the everypropertyai CLI)
EVERYPROPERTY_API_URL=http://localhost:3007   # PropertyIQ API; set to [PROPERTYIQ_PROD_URL] in prod
EVERYPROPERTY_API_TOKEN=                       # optional bearer if data routes get shared-secret auth
# EVERYPROPERTY_CLI_BIN=                        # optional: absolute path to dist/cli.js if not npm-linked
