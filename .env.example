# Required
NEXT_PUBLIC_BASE_URL=https://proposals.grantsea.com.au
AGENTMAIL_API_KEY=your_agentmail_key
AGENTMAIL_INBOX=newproposal@agentmail.to

# Optional
AGENCY_EMAIL=info@grantsea.com.au
APIFY_API_TOKEN=your_apify_token

# Railway volume (set automatically if using volume mount)
# DATABASE_PATH=/data/gea.db
# DATA_DIR=/data

# everypropertyAI (property data via authenticated HTTP API; server-side only)
EVERYPROPERTY_API_URL=https://geaeverypropertyai-production.up.railway.app
EVERYPROPERTY_API_TOKEN=                       # required bearer token for the everypropertyAI API
